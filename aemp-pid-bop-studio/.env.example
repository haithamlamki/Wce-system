# Copy to .env.local and fill in. The anon/publishable key is browser-safe;
# never put the service-role key here.
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Server/tooling only (NOT VITE_-prefixed → never bundled to the browser).
# Postgres connection strings (Prisma convention). Contains the DB password.
# Prisma reads these from `.env` (also gitignored), so copy them there for
# `npm run db:pull` / `db:generate`. DATABASE_URL = pooled (pgbouncer:6543);
# DIRECT_URL = direct (5432) for migrations/introspection.
DATABASE_URL="postgresql://postgres.<ref>:<password>@<host>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@<host>.pooler.supabase.com:5432/postgres"

# AEMP SSO (scaffold — see docs/INTEGRATION.md §SSO). Leave disabled until the
# `aemp-auth` Edge Function is deployed with AEMP's JWKS/claims.
VITE_AEMP_SSO_ENABLED=false
VITE_AEMP_AUTH_FN_URL=https://<ref>.supabase.co/functions/v1/aemp-auth
