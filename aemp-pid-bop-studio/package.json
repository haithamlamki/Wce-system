{
  "name": "aemp-pid-bop-studio",
  "private": true,
  "version": "0.1.0",
  "description": "P&ID & BOP Studio — Well Control Equipment module of Abraj Equipment Master Pro (Phase-1 production rewrite)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
